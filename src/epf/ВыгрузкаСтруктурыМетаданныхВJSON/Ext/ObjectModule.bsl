////////////////////////////////////////////////////////////////////////////////
// Модуль объекта внешней обработки "ВыгрузкаСтруктурыМетаданныхВJSON".
// Ядро обработки. Содержит весь программный API выгрузки структуры метаданных
// в JSON-файлы или в структуру данных 1С.
//
// Пример программного использования:
//
//   Обработка = ВнешниеОбработки.Создать("C:\ВыгрузкаСтруктурыМетаданныхВJSON.epf");
//   Ссылка = Справочники.ИдентификаторыОбъектовМетаданных.НайтиПоРеквизиту(
//       "ПолноеИмя", "Документ.РеализацияТоваровУслуг");
//
//   // Вариант 1: выгрузить в файл.
//   Результат = Обработка.ВыгрузитьОдинОбъект(Ссылка, "C:\Temp\");
//
//   // Вариант 2: получить описание в виде структуры без записи в файл.
//   Описание = Обработка.ПолучитьОписаниеОбъекта(Ссылка);
//
////////////////////////////////////////////////////////////////////////////////

#Область ПодключениеКакВнешняяОбработкаБСП

// Возвращает сведения о внешней обработке для регистрации в справочнике
// "ДополнительныеОтчётыИОбработки" подсистемы БСП.
//
// Требования к конфигурации:
//   - наличие БСП (подсистема "ДополнительныеОтчётыИОбработки");
//   - у пользователя — право на добавление дополнительных обработок.
//
// Возвращаемое значение:
//   Структура - стандартная структура сведений БСП:
//     * Вид                         - Строка - вид обработки ("ДополнительнаяОбработка").
//     * Назначение                  - Массив из Строка - полные имена объектов метаданных,
//                                     для которых доступна обработка (пусто — глобальная).
//     * Наименование                - Строка - отображаемое имя.
//     * Версия                      - Строка - версия обработки.
//     * БезопасныйРежим             - Булево - запускать ли в безопасном режиме.
//     * Информация                  - Строка - краткое описание для пользователя.
//     * ВариантЗапуска              - Строка - "ОткрытиеФормы" | "ВызовСерверногоМетода" |
//                                     "ВызовКлиентскогоМетода" | "СценарийВКомандахКлиента".
//     * Команды                     - ТаблицаЗначений - описание команд.
//
Функция СведенияОВнешнейОбработке() Экспорт

    ПараметрыРегистрации = Новый Структура;
    ПараметрыРегистрации.Вставить("Вид",              "ДополнительнаяОбработка");
    ПараметрыРегистрации.Вставить("Назначение",       Новый Массив); // глобальная обработка
    ПараметрыРегистрации.Вставить("Наименование",     "Выгрузка структуры метаданных в JSON");
    ПараметрыРегистрации.Вставить("Версия",           "1.0.0");
    ПараметрыРегистрации.Вставить("БезопасныйРежим",  Ложь);
    ПараметрыРегистрации.Вставить("Информация",
        "Выгружает структуру объектов метаданных (справочников, документов, регистров, " +
        "подсистем) в JSON-файлы. Поддерживает объекты расширений конфигурации. " +
        "Работает в любой конфигурации на платформе 8.3.27+.");

    ПараметрыРегистрации.Вставить("Команды", ТаблицаКомандОбработки());

    Возврат ПараметрыРегистрации;

КонецФункции

Функция ТаблицаКомандОбработки()

    Команды = Новый ТаблицаЗначений;
    Команды.Колонки.Добавить("Представление",    Новый ОписаниеТипов("Строка"));
    Команды.Колонки.Добавить("Идентификатор",    Новый ОписаниеТипов("Строка"));
    Команды.Колонки.Добавить("Использование",    Новый ОписаниеТипов("Строка"));
    Команды.Колонки.Добавить("ПоказыватьОповещение", Новый ОписаниеТипов("Булево"));
    Команды.Колонки.Добавить("Модификатор",      Новый ОписаниеТипов("Строка"));

    НоваяКоманда = Команды.Добавить();
    НоваяКоманда.Представление        = "Открыть обработку выгрузки метаданных в JSON";
    НоваяКоманда.Идентификатор        = "ОткрытьФормуВыгрузки";
    НоваяКоманда.Использование        = "ОткрытиеФормы";
    НоваяКоманда.ПоказыватьОповещение = Ложь;
    НоваяКоманда.Модификатор          = "";

    Возврат Команды;

КонецФункции

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Конструктор структуры параметров выгрузки.
// Все поля имеют значения по умолчанию — заполните только те, которые отличаются.
//
// Возвращаемое значение:
//   Структура:
//     * Режим                              - Строка - "Один" | "Список" | "Подсистема".
//     * ОбъектВыгрузки                     - Строка - полное имя объекта метаданных,
//                                            например "Документ.РеализацияТоваровУслуг".
//                                            Используется при Режим = "Один".
//     * СписокОбъектов                     - СписокЗначений, Массив - элементы/значения
//                                            содержат строки полных имён объектов.
//                                            Используется при Режим = "Список".
//     * Подсистема                         - Строка - полное имя подсистемы,
//                                            например "Подсистема.Продажи.Розница".
//                                            Используется при Режим = "Подсистема".
//     * ВыгружатьОбъектыВложенныхПодсистем - Булево - учитывать состав вложенных подсистем.
//     * РежимСсылочныхТипов                - Строка - "Кратко" | "Раскрывать".
//     * ГлубинаВложенности                 - Число  - 1..3, действует при "Раскрывать".
//     * РежимДвиженийРегистров             - Строка - "Коротко" | "Подробно".
//     * ВключатьПредопределенные           - Булево - включать имена предопределённых.
//     * КомпактныйJSON                     - Булево - без отступов и переносов.
//     * ПапкаВыгрузки                      - Строка - путь к папке для записи файлов.
//     * ОтдельныеФайлы                     - Булево - Ложь = один файл, Истина = файл на объект.
//     * ДобавлятьВременнуюМетку            - Булево - добавлять _yyyyMMdd_HHmmss к имени файла.
//
Функция НовыеПараметрыВыгрузки() Экспорт
    Параметры = Новый Структура;
    Параметры.Вставить("Режим",                              "Один");
    Параметры.Вставить("ОбъектВыгрузки",                     "");
    Параметры.Вставить("СписокОбъектов",                     Неопределено);
    Параметры.Вставить("Подсистема",                         "");
    Параметры.Вставить("ВыгружатьОбъектыВложенныхПодсистем", Истина);
    Параметры.Вставить("РежимСсылочныхТипов",                "Кратко");
    Параметры.Вставить("ГлубинаВложенности",                 1);
    Параметры.Вставить("РежимДвиженийРегистров",             "Подробно");
    Параметры.Вставить("ВключатьПредопределенные",           Истина);
    Параметры.Вставить("КомпактныйJSON",                     Ложь);
    Параметры.Вставить("ПапкаВыгрузки",                      "");
    Параметры.Вставить("ОтдельныеФайлы",                     Ложь);
    Параметры.Вставить("ДобавлятьВременнуюМетку",            Ложь);
    Возврат Параметры;
КонецФункции

// Основная точка входа. Диспетчеризует режим и создаёт файлы JSON.
//
// Параметры:
//   Параметры - Структура - см. НовыеПараметрыВыгрузки().
//
// Возвращаемое значение:
//   Структура:
//     * Успех             - Булево.
//     * СообщениеОбОшибке - Строка.
//     * СозданныеФайлы    - Массив из Строка - полные пути созданных файлов.
//
Функция Выгрузить(Параметры) Экспорт
    Результат = НовыйРезультатВыгрузки();

    ПроверкаПараметров = ПроверитьПараметры(Параметры);
    Если НЕ ПроверкаПараметров.Успех Тогда
        Результат.Успех = Ложь;
        Результат.СообщениеОбОшибке = ПроверкаПараметров.СообщениеОбОшибке;
        Возврат Результат;
    КонецЕсли;

    СписокПолныхИмён = СобратьСписокПолныхИмёнОбъектов(Параметры);

    БлокПодсистемы = Неопределено;
    Если Параметры.Режим = "Подсистема" Тогда
        ОбъектПС = ОбъектМетаданныхПоПолномуИмени(Параметры.Подсистема);
        Если ОбъектПС <> Неопределено Тогда
            БлокПодсистемы = ОписаниеПодсистемы(ОбъектПС);
        КонецЕсли;
    КонецЕсли;

    Если Параметры.ОтдельныеФайлы Тогда
        ВыгрузитьОтдельнымиФайлами(СписокПолныхИмён, БлокПодсистемы, Параметры, Результат);
    Иначе
        ВыгрузитьОбщимФайлом(СписокПолныхИмён, БлокПодсистемы, Параметры, Результат);
    КонецЕсли;

    Возврат Результат;
КонецФункции

// Обёртка: выгрузить один объект в файл.
//
// Параметры:
//   ПолноеИмяОбъекта - Строка - например "Документ.РеализацияТоваровУслуг".
//   ПапкаВыгрузки    - Строка - путь к папке.
//   ДопПараметры     - Структура - см. НовыеПараметрыВыгрузки().
//
Функция ВыгрузитьОдинОбъект(ПолноеИмяОбъекта, ПапкаВыгрузки, ДопПараметры = Неопределено) Экспорт
    Параметры = ?(ДопПараметры = Неопределено, НовыеПараметрыВыгрузки(), ДопПараметры);
    Параметры.Режим          = "Один";
    Параметры.ОбъектВыгрузки = ПолноеИмяОбъекта;
    Параметры.ПапкаВыгрузки  = ПапкаВыгрузки;
    Возврат Выгрузить(Параметры);
КонецФункции

// Обёртка: выгрузить список объектов.
//
// Параметры:
//   СписокПолныхИмён - СписокЗначений, Массив - элементы содержат строки полных имён.
//   ПапкаВыгрузки    - Строка - путь к папке.
//   ДопПараметры     - Структура - см. НовыеПараметрыВыгрузки().
//
Функция ВыгрузитьСписок(СписокПолныхИмён, ПапкаВыгрузки, ДопПараметры = Неопределено) Экспорт
    Параметры = ?(ДопПараметры = Неопределено, НовыеПараметрыВыгрузки(), ДопПараметры);
    Параметры.Режим          = "Список";
    Параметры.СписокОбъектов = СписокПолныхИмён;
    Параметры.ПапкаВыгрузки  = ПапкаВыгрузки;
    Возврат Выгрузить(Параметры);
КонецФункции

// Обёртка: выгрузить подсистему.
//
// Параметры:
//   ПолноеИмяПодсистемы - Строка - например "Подсистема.Продажи.Розница".
//   ПапкаВыгрузки       - Строка.
//   ВключатьВложенные   - Булево.
//   ДопПараметры        - Структура.
//
Функция ВыгрузитьПодсистему(ПолноеИмяПодсистемы, ПапкаВыгрузки, ВключатьВложенные = Истина, ДопПараметры = Неопределено) Экспорт
    Параметры = ?(ДопПараметры = Неопределено, НовыеПараметрыВыгрузки(), ДопПараметры);
    Параметры.Режим                              = "Подсистема";
    Параметры.Подсистема                         = ПолноеИмяПодсистемы;
    Параметры.ВыгружатьОбъектыВложенныхПодсистем = ВключатьВложенные;
    Параметры.ПапкаВыгрузки                      = ПапкаВыгрузки;
    Возврат Выгрузить(Параметры);
КонецФункции

// Возвращает структуру-описание объекта метаданных без записи в файл.
// Полезно для прямой передачи в HTTP-запрос к LLM или для использования
// результата в вызывающем коде.
//
// Параметры:
//   ПолноеИмяОбъекта - Строка - например "Документ.РеализацияТоваровУслуг".
//   Параметры        - Структура - см. НовыеПараметрыВыгрузки().
//                      Если Неопределено — значения по умолчанию.
//                      Влияют поля: РежимСсылочныхТипов, ГлубинаВложенности,
//                      РежимДвиженийРегистров, ВключатьПредопределенные.
//   ПосещенныеТипы   - Соответствие - внешний контекст защиты от рекурсии.
//                      Если Неопределено — создаётся локально. Передавайте извне,
//                      если нужна сквозная защита по набору объектов (общий файл).
//
// Возвращаемое значение:
//   Структура - описание объекта, либо Неопределено, если объект не найден.
//
Функция ПолучитьОписаниеОбъекта(ПолноеИмяОбъекта, Параметры = Неопределено, ПосещенныеТипы = Неопределено) Экспорт
    Если Параметры = Неопределено Тогда
        Параметры = НовыеПараметрыВыгрузки();
    КонецЕсли;
    Если ПосещенныеТипы = Неопределено Тогда
        ПосещенныеТипы = Новый Соответствие;
    КонецЕсли;

    ОбъектМД = ОбъектМетаданныхПоПолномуИмени(ПолноеИмяОбъекта);
    Если ОбъектМД = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    НастройкиОписания = НастройкиОписанияИзПараметров(Параметры);
    Возврат ОписаниеОбъекта(ОбъектМД, ПосещенныеТипы, 0, НастройкиОписания);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции_Оркестрация

Функция ОбъектМетаданныхПоПолномуИмени(ПолноеИмя, ВызыватьИсключениеПриОтсутствии = Ложь)
    
    Если ПустаяСтрока(ПолноеИмя) Тогда
        Возврат Неопределено;
    КонецЕсли;
    
    ОбъектМД = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
    
    Если ОбъектМД = Неопределено И ВызыватьИсключениеПриОтсутствии Тогда
        ВызватьИсключение СтрШаблон(
            НСтр("ru = 'Объект метаданных ""%1"" не найден в текущей конфигурации.'"),
            ПолноеИмя);
    КонецЕсли;
    
    Возврат ОбъектМД;
    
КонецФункции

Функция НовыйРезультатВыгрузки()
    Результат = Новый Структура;
    Результат.Вставить("Успех",             Истина);
    Результат.Вставить("СообщениеОбОшибке", "");
    Результат.Вставить("СозданныеФайлы",    Новый Массив);
    Возврат Результат;
КонецФункции

Функция ПроверитьПараметры(Параметры)
    Результат = Новый Структура("Успех, СообщениеОбОшибке", Истина, "");

    Если ПустаяСтрока(Параметры.ПапкаВыгрузки) Тогда
        Результат.Успех = Ложь;
        Результат.СообщениеОбОшибке = "Не указана папка выгрузки.";
        Возврат Результат;
    КонецЕсли;

    ДопустимыеРежимы = Новый Массив;
    ДопустимыеРежимы.Добавить("Один");
    ДопустимыеРежимы.Добавить("Список");
    ДопустимыеРежимы.Добавить("Подсистема");
    Если ДопустимыеРежимы.Найти(Параметры.Режим) = Неопределено Тогда
        Результат.Успех = Ложь;
        Результат.СообщениеОбОшибке = "Недопустимый режим: " + Параметры.Режим;
        Возврат Результат;
    КонецЕсли;

    Если Параметры.Режим = "Один" И ПустаяСтрока(Параметры.ОбъектВыгрузки) Тогда
        Результат.Успех = Ложь;
        Результат.СообщениеОбОшибке = "Режим ""Один"": не задано полное имя объекта выгрузки.";
    ИначеЕсли Параметры.Режим = "Список" И КоличествоЭлементов(Параметры.СписокОбъектов) = 0 Тогда
        Результат.Успех = Ложь;
        Результат.СообщениеОбОшибке = "Режим ""Список"": пустой СписокОбъектов.";
    ИначеЕсли Параметры.Режим = "Подсистема" И ПустаяСтрока(Параметры.Подсистема) Тогда
        Результат.Успех = Ложь;
        Результат.СообщениеОбОшибке = "Режим ""Подсистема"": не задано полное имя подсистемы.";
    КонецЕсли;

    Если Параметры.РежимСсылочныхТипов = "Раскрывать"
       И (Параметры.ГлубинаВложенности < 1 ИЛИ Параметры.ГлубинаВложенности > 3) Тогда
        Результат.Успех = Ложь;
        Результат.СообщениеОбОшибке = "Глубина вложенности должна быть от 1 до 3.";
    КонецЕсли;

    Возврат Результат;
КонецФункции

Функция КоличествоЭлементов(Коллекция)
    Если Коллекция = Неопределено Тогда
        Возврат 0;
    КонецЕсли;
    Если ТипЗнч(Коллекция) = Тип("СписокЗначений") Тогда
        Возврат Коллекция.Количество();
    ИначеЕсли ТипЗнч(Коллекция) = Тип("Массив") Тогда
        Возврат Коллекция.Количество();
    КонецЕсли;
    Возврат 0;
КонецФункции

Процедура ВыгрузитьОбщимФайлом(СписокПолныхИмён, БлокПодсистемы, Параметры, Результат)
    // Общий файл — защита от рекурсии глобальная: один контекст ПосещенныеТипы
    // на весь файл. Повторные встречи типов свёртываются в {ПолноеИмя, Рекурсия=Истина}.
   
    ПосещенныеТипы = Новый Соответствие;

    МассивОбъектов = Новый Массив;
    Для Каждого ПолноеИмя Из СписокПолныхИмён Цикл
        Описание = ПолучитьОписаниеОбъекта(ПолноеИмя, Параметры, ПосещенныеТипы);
        Если Описание <> Неопределено Тогда
            МассивОбъектов.Добавить(Описание);
        КонецЕсли;
    КонецЦикла;

    Корень = Новый Структура;
    Корень.Вставить("Конфигурация", Метаданные.Имя);
    Корень.Вставить("Версия",       Метаданные.Версия);
    Корень.Вставить("ДатаВыгрузки", ТекущаяДатаСеанса());
    Если БлокПодсистемы <> Неопределено Тогда
        Корень.Вставить("Подсистема", БлокПодсистемы);
    КонецЕсли;
    Корень.Вставить("Объекты", МассивОбъектов);

    ИмяФайла = ОбъединитьПуть(Параметры.ПапкаВыгрузки,
        ИмяОбщегоФайлаВыгрузки(Параметры, СписокПолныхИмён) + ".json");
    ЗаписатьJSONВФайл(ИмяФайла, Корень, Параметры.КомпактныйJSON);
    Результат.СозданныеФайлы.Добавить(ИмяФайла);

КонецПроцедуры

Процедура ВыгрузитьОтдельнымиФайлами(СписокПолныхИмён, БлокПодсистемы, Параметры, Результат)
    // Отдельные файлы — защита от рекурсии в пределах одного файла:
    // ПосещенныеТипы сбрасывается для каждого объекта, чтобы каждый файл
    // содержал максимально полный контекст для LLM.
    Для Каждого ПолноеИмя Из СписокПолныхИмён Цикл
        ПосещенныеТипы = Новый Соответствие;
        Описание = ПолучитьОписаниеОбъекта(ПолноеИмя, Параметры, ПосещенныеТипы);
        Если Описание = Неопределено Тогда
            Продолжить;
        КонецЕсли;

        КореньФайла = Новый Структура;
        Если БлокПодсистемы <> Неопределено Тогда
            КореньФайла.Вставить("Подсистема", БлокПодсистемы);
        КонецЕсли;
        КореньФайла.Вставить("Объект", Описание);

        ИмяФайла = ОбъединитьПуть(Параметры.ПапкаВыгрузки, БезопасноеИмяФайла(ПолноеИмя) + ".json");
        ЗаписатьJSONВФайл(ИмяФайла, КореньФайла, Параметры.КомпактныйJSON);
        Результат.СозданныеФайлы.Добавить(ИмяФайла);
    КонецЦикла;
КонецПроцедуры

Функция НастройкиОписанияИзПараметров(Параметры)
    Настройки = Новый Структура;
    Настройки.Вставить("РежимСсылочныхТипов",      Параметры.РежимСсылочныхТипов);
    Настройки.Вставить("ГлубинаВложенности",
        ?(Параметры.РежимСсылочныхТипов = "Раскрывать",
          Мин(3, Макс(1, Параметры.ГлубинаВложенности)),
          0));
    Настройки.Вставить("РежимДвиженийРегистров",   Параметры.РежимДвиженийРегистров);
    Настройки.Вставить("ВключатьПредопределенные", Параметры.ВключатьПредопределенные);
    Возврат Настройки;
КонецФункции

Функция СобратьСписокПолныхИмёнОбъектов(Параметры)
    Массив = Новый Массив;
    Если Параметры.Режим = "Один" Тогда
        Если НЕ ПустаяСтрока(Параметры.ОбъектВыгрузки) Тогда
            Массив.Добавить(Параметры.ОбъектВыгрузки);
        КонецЕсли;
    ИначеЕсли Параметры.Режим = "Список" Тогда
        Если ТипЗнч(Параметры.СписокОбъектов) = Тип("СписокЗначений") Тогда
            Для Каждого Эл Из Параметры.СписокОбъектов Цикл
                Если НЕ ПустаяСтрока(Эл.Значение) Тогда
                    Массив.Добавить(Эл.Значение);
                КонецЕсли;
            КонецЦикла;
        ИначеЕсли ТипЗнч(Параметры.СписокОбъектов) = Тип("Массив") Тогда
            Для Каждого Эл Из Параметры.СписокОбъектов Цикл
                Если НЕ ПустаяСтрока(Эл) Тогда
                    Массив.Добавить(Эл);
                КонецЕсли;
            КонецЦикла;
        КонецЕсли;
    ИначеЕсли Параметры.Режим = "Подсистема" Тогда
        ОбъектПС = ОбъектМетаданныхПоПолномуИмени(Параметры.Подсистема);
        Если ОбъектПС <> Неопределено Тогда
            СобратьОбъектыПодсистемыРекурсивно(ОбъектПС, Массив, Параметры.ВыгружатьОбъектыВложенныхПодсистем);
        КонецЕсли;
    КонецЕсли;
    Возврат Массив;
КонецФункции

Процедура СобратьОбъектыПодсистемыРекурсивно(ОбъектПодсистемы, МассивРезультат, ВключатьВложенные)
    Для Каждого ОбъектМД Из ОбъектПодсистемы.Состав Цикл
        Попытка
            МассивРезультат.Добавить(ОбъектМД.ПолноеИмя());
        Исключение
            ЗаписьЖурналаРегистрации("ВыгрузкаJSON",
                УровеньЖурналаРегистрации.Предупреждение, , ,
                "Не удалось получить полное имя объекта состава подсистемы.");
        КонецПопытки;
    КонецЦикла;
    Если ВключатьВложенные Тогда
        Для Каждого ВложПС Из ОбъектПодсистемы.Подсистемы Цикл
            СобратьОбъектыПодсистемыРекурсивно(ВложПС, МассивРезультат, Истина);
        КонецЦикла;
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции_ОписаниеМетаданных

Функция ОписаниеПодсистемы(ОбъектПС)
    Описание = Новый Структура;
    Описание.Вставить("Имя",       ОбъектПС.Имя);
    Описание.Вставить("Синоним",   ОбъектПС.Синоним);
    Описание.Вставить("ПолноеИмя", ОбъектПС.ПолноеИмя());

    // Иерархия родителей — упорядочена от корня к текущей подсистеме.
    ПутьРодителей = Новый Массив;
    Родитель = ОбъектПС.Родитель();
    Пока Родитель <> Неопределено И Метаданные.Подсистемы.Содержит(Родитель) Цикл
        ПутьРодителей.Вставить(0, Родитель.Имя);
        Родитель = Родитель.Родитель();
    КонецЦикла;
    Описание.Вставить("ПутьРодителей", ПутьРодителей);

    Возврат Описание;
КонецФункции

Функция ОписаниеОбъекта(ОбъектМД, ПосещенныеТипы, Уровень, Настройки)
    // Универсальное описание объекта метаданных любого вида.
    Описание = Новый Структура;
    Описание.Вставить("ВидОбъекта",  ВидОбъектаМетаданных(ОбъектМД));
    Описание.Вставить("Имя",         ОбъектМД.Имя);
    Описание.Вставить("Синоним",     ОбъектМД.Синоним);
    Описание.Вставить("ПолноеИмя",   ОбъектМД.ПолноеИмя());
    Описание.Вставить("Комментарий", ОбъектМД.Комментарий);

    // Стандартные реквизиты (Ссылка, Дата, Номер, Проведён, ПометкаУдаления ...).
    Описание.Вставить("СтандартныеРеквизиты", ОписанияСтандартныхРеквизитов(ОбъектМД));

    // Реквизиты шапки.
    Попытка
        Описание.Вставить("Реквизиты",
            ОписанияРеквизитов(ОбъектМД.Реквизиты, ПосещенныеТипы, Уровень, Настройки));
    Исключение
        // У некоторых объектов нет коллекции Реквизиты — пропускаем.
    КонецПопытки;

    // Табличные части.
    Если СвойствоСуществует(ОбъектМД, "ТабличныеЧасти") Тогда
        МассивТЧ = Новый Массив;
        Для Каждого ТЧ Из ОбъектМД.ТабличныеЧасти Цикл
            ОписаниеТЧ = Новый Структура;
            ОписаниеТЧ.Вставить("Имя",       ТЧ.Имя);
            ОписаниеТЧ.Вставить("Синоним",   ТЧ.Синоним);
            ОписаниеТЧ.Вставить("Реквизиты",
                ОписанияРеквизитов(ТЧ.Реквизиты, ПосещенныеТипы, Уровень, Настройки));
            МассивТЧ.Добавить(ОписаниеТЧ);
        КонецЦикла;
        Описание.Вставить("ТабличныеЧасти", МассивТЧ);
    КонецЕсли;

    // Движения документа.
    Если Метаданные.Документы.Содержит(ОбъектМД) Тогда
        Описание.Вставить("Движения",
            ОписанияДвижений(ОбъектМД, ПосещенныеТипы, Уровень, Настройки));
    КонецЕсли;

    // Специфика регистров: измерения и ресурсы.
    Если ЭтоРегистр(ОбъектМД) Тогда
        Описание.Вставить("Измерения",
            ОписанияРеквизитов(ОбъектМД.Измерения, ПосещенныеТипы, Уровень, Настройки));
        Если СвойствоСуществует(ОбъектМД, "Ресурсы") Тогда
            Описание.Вставить("Ресурсы",
                ОписанияРеквизитов(ОбъектМД.Ресурсы, ПосещенныеТипы, Уровень, Настройки));
        КонецЕсли;
    КонецЕсли;

    // Предопределённые элементы.
    Если Настройки.ВключатьПредопределенные И ПоддерживаетПредопределенные(ОбъектМД) Тогда
        Описание.Вставить("Предопределённые", ИменаПредопределенных(ОбъектМД));
    КонецЕсли;

    Возврат Описание;
КонецФункции

Функция ОписанияСтандартныхРеквизитов(ОбъектМД)
    Массив = Новый Массив;
    Попытка
        Для Каждого СтандРек Из ОбъектМД.СтандартныеРеквизиты Цикл
            Элемент = Новый Структура;
            Элемент.Вставить("Имя",     СтандРек.Имя);
            Элемент.Вставить("Синоним", СтандРек.Синоним);
            Элемент.Вставить("Типы",    ИменаТиповОписания(СтандРек.Тип));
            Массив.Добавить(Элемент);
        КонецЦикла;
    Исключение
        // Не у всех объектов есть коллекция СтандартныеРеквизиты — молча пропускаем.
    КонецПопытки;
    Возврат Массив;
КонецФункции

Функция ОписанияРеквизитов(Коллекция, ПосещенныеТипы, Уровень, Настройки)
    Массив = Новый Массив;
    Для Каждого Реквизит Из Коллекция Цикл
        Элемент = Новый Структура;
        Элемент.Вставить("Имя",         Реквизит.Имя);
        Элемент.Вставить("Синоним",     Реквизит.Синоним);
        Элемент.Вставить("Комментарий", Реквизит.Комментарий);
        Элемент.Вставить("Типы",        ИменаТиповОписания(Реквизит.Тип));

        // Квалификаторы числового типа (Длина/Точность).
        Попытка
            КвЧисла = Реквизит.Тип.КвалификаторыЧисла;
            Если КвЧисла.Разрядность > 0 Тогда
                Элемент.Вставить("Длина",    КвЧисла.Разрядность);
                Элемент.Вставить("Точность", КвЧисла.РазрядностьДробнойЧасти);
            КонецЕсли;
        Исключение
        КонецПопытки;

        // Квалификаторы строкового типа (длина строки).
        Попытка
            КвСтроки = Реквизит.Тип.КвалификаторыСтроки;
            Если КвСтроки.Длина > 0 Тогда
                Элемент.Вставить("ДлинаСтроки", КвСтроки.Длина);
            КонецЕсли;
        Исключение
        КонецПопытки;

        // Проверка заполнения — полезна LLM для понимания обязательности реквизита.
        Попытка
            Элемент.Вставить("ПроверкаЗаполнения", Строка(Реквизит.ПроверкаЗаполнения));
        Исключение
        КонецПопытки;

        // Раскрытие ссылочных типов — если включено и не достигнут предел глубины.
        Если Настройки.РежимСсылочныхТипов = "Раскрывать" И Уровень < Настройки.ГлубинаВложенности Тогда
            Раскрытие = РаскрытьСсылочныеТипы(Реквизит.Тип, ПосещенныеТипы, Уровень, Настройки);
            Если Раскрытие.Количество() > 0 Тогда
                Элемент.Вставить("Раскрытие", Раскрытие);
            КонецЕсли;
        КонецЕсли;

        Массив.Добавить(Элемент);
    КонецЦикла;
    Возврат Массив;
КонецФункции

Функция РаскрытьСсылочныеТипы(ОписаниеТипов, ПосещенныеТипы, Уровень, Настройки)
    Массив = Новый Массив;
    Для Каждого Тип Из ОписаниеТипов.Типы() Цикл
        ОбъектМДЦели = Метаданные.НайтиПоТипу(Тип);
        Если ОбъектМДЦели = Неопределено Тогда
            Продолжить;
        КонецЕсли;

        ПолноеИмяЦели = ОбъектМДЦели.ПолноеИмя();
        Если ПосещенныеТипы.Получить(ПолноеИмяЦели) <> Неопределено Тогда
            // Рекурсия — повторно встреченный тип свёртываем в маркер.
            Маркер = Новый Структура;
            Маркер.Вставить("ПолноеИмя", ПолноеИмяЦели);
            Маркер.Вставить("Рекурсия", Истина);
            Массив.Добавить(Маркер);
            Продолжить;
        КонецЕсли;

        ПосещенныеТипы.Вставить(ПолноеИмяЦели, Истина);
        Массив.Добавить(ОписаниеОбъекта(ОбъектМДЦели, ПосещенныеТипы, Уровень + 1, Настройки));
    КонецЦикла;
    Возврат Массив;
КонецФункции

Функция ОписанияДвижений(ДокументМД, ПосещенныеТипы, Уровень, Настройки)
    Массив = Новый Массив;
    Для Каждого РегистрМД Из ДокументМД.Движения Цикл
        Описание = Новый Структура;
        Описание.Вставить("Вид",       ВидОбъектаМетаданных(РегистрМД));
        Описание.Вставить("Имя",       РегистрМД.Имя);
        Описание.Вставить("Синоним",   РегистрМД.Синоним);
        Описание.Вставить("ПолноеИмя", РегистрМД.ПолноеИмя());

        Если Настройки.РежимДвиженийРегистров = "Подробно" Тогда
            Описание.Вставить("Измерения",
                ОписанияРеквизитов(РегистрМД.Измерения, ПосещенныеТипы, Уровень, Настройки));
            Если СвойствоСуществует(РегистрМД, "Ресурсы") Тогда
                Описание.Вставить("Ресурсы",
                    ОписанияРеквизитов(РегистрМД.Ресурсы, ПосещенныеТипы, Уровень, Настройки));
            КонецЕсли;
            Попытка
                Описание.Вставить("Реквизиты",
                    ОписанияРеквизитов(РегистрМД.Реквизиты, ПосещенныеТипы, Уровень, Настройки));
            Исключение
            КонецПопытки;
        КонецЕсли;

        Массив.Добавить(Описание);
    КонецЦикла;
    Возврат Массив;
КонецФункции

Функция ИменаПредопределенных(ОбъектМД)
    Массив = Новый Массив;
    Попытка
        // Универсальный способ для Справочников/ПВХ/ПС/ПВР.
        Для Каждого Предопределенный Из ОбъектМД.ПолучитьПредставленияПредопределенных() Цикл
            Массив.Добавить(Предопределенный);
        КонецЦикла;
    Исключение
        // Для Перечислений — перебор коллекции ЗначенияПеречисления.
        Попытка
            Для Каждого Значение Из ОбъектМД.ЗначенияПеречисления Цикл
                Массив.Добавить(Значение.Имя);
            КонецЦикла;
        Исключение
        КонецПопытки;
    КонецПопытки;
    Возврат Массив;
КонецФункции

Функция ИменаТиповОписания(ОписаниеТипов)
    Массив = Новый Массив;
    Для Каждого Тип Из ОписаниеТипов.Типы() Цикл
        ОбъектМД = Метаданные.НайтиПоТипу(Тип);
        Если ОбъектМД <> Неопределено Тогда
            Массив.Добавить(ОбъектМД.ПолноеИмя());
        Иначе
            // Примитивный или платформенный тип (Строка, Число, Дата, Булево, УникальныйИдентификатор и т.д.).
            Массив.Добавить(Строка(Тип));
        КонецЕсли;
    КонецЦикла;
    Возврат Массив;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции_Утилиты

Функция ВидОбъектаМетаданных(ОбъектМД)
    // Вид определяется префиксом полного имени: "Документ.XXX" → "Документ".
    ПолноеИмя = ОбъектМД.ПолноеИмя();
    ТочкаПоз = СтрНайти(ПолноеИмя, ".");
    Возврат ?(ТочкаПоз > 0, Лев(ПолноеИмя, ТочкаПоз - 1), ПолноеИмя);
КонецФункции

Функция ЭтоРегистр(ОбъектМД)
    Возврат Метаданные.РегистрыСведений.Содержит(ОбъектМД)
        Или Метаданные.РегистрыНакопления.Содержит(ОбъектМД)
        Или Метаданные.РегистрыБухгалтерии.Содержит(ОбъектМД)
        Или Метаданные.РегистрыРасчета.Содержит(ОбъектМД);
КонецФункции

Функция ПоддерживаетПредопределенные(ОбъектМД)
    Возврат Метаданные.Справочники.Содержит(ОбъектМД)
        Или Метаданные.Перечисления.Содержит(ОбъектМД)
        Или Метаданные.ПланыВидовХарактеристик.Содержит(ОбъектМД)
        Или Метаданные.ПланыСчетов.Содержит(ОбъектМД)
        Или Метаданные.ПланыВидовРасчета.Содержит(ОбъектМД);
КонецФункции

Функция СвойствоСуществует(ОбъектМД, ИмяСвойства)
    // Проверка наличия свойства через Попытку — у разных видов метаданных разные коллекции.
    Попытка
        Значение = ОбъектМД[ИмяСвойства];
        Возврат Истина;
    Исключение
        Возврат Ложь;
    КонецПопытки;
КонецФункции

Функция БезопасноеИмяФайла(Значение)
    Результат = Значение;
    ЗапрещенныеСимволы = Новый Массив;
    ЗапрещенныеСимволы.Добавить("""");
    ЗапрещенныеСимволы.Добавить("*");
    ЗапрещенныеСимволы.Добавить("/");
    ЗапрещенныеСимволы.Добавить("\");
    ЗапрещенныеСимволы.Добавить(":");
    ЗапрещенныеСимволы.Добавить("<");
    ЗапрещенныеСимволы.Добавить(">");
    ЗапрещенныеСимволы.Добавить("?");
    ЗапрещенныеСимволы.Добавить("|");
    Для Каждого Симв Из ЗапрещенныеСимволы Цикл
        Результат = СтрЗаменить(Результат, Симв, "_");
    КонецЦикла;
    Возврат Результат;
КонецФункции

Функция ОбъединитьПуть(Папка, Файл)
    Если ПустаяСтрока(Папка) Тогда
        Возврат Файл;
    КонецЕсли;
    ПоследнийСимвол = Прав(Папка, 1);
    Если ПоследнийСимвол = "\" ИЛИ ПоследнийСимвол = "/" Тогда
        Возврат Папка + Файл;
    КонецЕсли;
    Разделитель = ?(СтрНайти(Папка, "\") > 0, "\", "/");
    Возврат Папка + Разделитель + Файл;
КонецФункции

Процедура ЗаписатьJSONВФайл(ИмяФайла, Данные, Компактный = Ложь)
    ПереносСтрок = ?(Компактный, ПереносСтрокJSON.Нет,  ПереносСтрокJSON.Авто);
    ОтступСимвол = ?(Компактный, "",                   Символы.Таб);

    ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрок, ОтступСимвол, Истина);
    Запись = Новый ЗаписьJSON;
    Запись.ОткрытьФайл(ИмяФайла, "UTF-8", Ложь, ПараметрыЗаписи);

    НастройкиСериализации = Новый НастройкиСериализацииJSON;
    НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;

    ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
    Запись.Закрыть();
КонецПроцедуры   

Функция ИмяОбщегоФайлаВыгрузки(Параметры, СписокПолныхИмён)
    // Определяем базовое имя в зависимости от режима.
    БазовоеИмя = "";
    Если Параметры.Режим = "Один" И СписокПолныхИмён.Количество() > 0 Тогда
        БазовоеИмя = БезопасноеИмяФайла(СписокПолныхИмён[0]);
    ИначеЕсли Параметры.Режим = "Подсистема" И НЕ ПустаяСтрока(Параметры.Подсистема) Тогда
        БазовоеИмя = БезопасноеИмяФайла(Параметры.Подсистема);
    КонецЕсли;

    // Для "Список" и как fallback — префикс с меткой времени.
    Если ПустаяСтрока(БазовоеИмя) Тогда
        БазовоеИмя = "metadata_list_" + Формат(ТекущаяДатаСеанса(), "ДФ=yyyyMMdd_HHmmss");
        Возврат БазовоеИмя; // метка уже в имени, ещё раз добавлять не нужно
    КонецЕсли;

    Если Параметры.ДобавлятьВременнуюМетку Тогда
        БазовоеИмя = БазовоеИмя + "_" + Формат(ТекущаяДатаСеанса(), "ДФ=yyyyMMdd_HHmmss");
    КонецЕсли;

    Возврат БазовоеИмя;
КонецФункции

#КонецОбласти