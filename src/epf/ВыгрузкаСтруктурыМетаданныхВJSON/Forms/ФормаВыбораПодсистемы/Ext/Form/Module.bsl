#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    Заголовок = НСтр("ru = 'Выбор подсистемы'");
    ПостроитьДерево();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийРеквизитов

&НаКлиенте
Процедура СтрокаПоискаПриИзменении(Элемент)
    ПостроитьДеревоНаСервере();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиТаблицыДерева

&НаКлиенте
Процедура ДеревоПодсистемВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
    СтандартнаяОбработка = Ложь;
    ВыбратьВыполнить(Неопределено);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКоманд

&НаКлиенте
Процедура ВыбратьВыполнить(Команда)
    
    ТекущиеДанные = Элементы.ДеревоПодсистем.ТекущиеДанные;
    Если ТекущиеДанные = Неопределено Тогда
        ПоказатьПредупреждение(, НСтр("ru = 'Выберите подсистему.'"));
        Возврат;
    КонецЕсли;
    
    Если ПустаяСтрока(ТекущиеДанные.ПолноеИмя) Тогда
        ПоказатьПредупреждение(, НСтр("ru = 'Не удалось определить полное имя подсистемы.'"));
        Возврат;
    КонецЕсли;
    
    ОповеститьОВыборе(ТекущиеДанные.ПолноеИмя);
    
КонецПроцедуры

&НаКлиенте
Процедура ОтменаВыполнить(Команда)
    Закрыть(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьВсё(Команда)
    РазвернутьИлиСвернутьВсе(Истина);
КонецПроцедуры

&НаКлиенте
Процедура СвернутьВсё(Команда)
    РазвернутьИлиСвернутьВсе(Ложь);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПостроитьДеревоНаСервере()
    ПостроитьДерево();
КонецПроцедуры

&НаСервере
Процедура ПостроитьДерево()
    
    Дерево = РеквизитФормыВЗначение("ДеревоПодсистем");
    Дерево.Строки.Очистить();
    
    ПоискВНижнем   = НРег(СокрЛП(СтрокаПоиска));
    ПрименятьПоиск = НЕ ПустаяСтрока(ПоискВНижнем);
    
    Для Каждого Подсистема Из Метаданные.Подсистемы Цикл
        ДобавитьПодсистемуВДерево(Дерево, Подсистема, ПоискВНижнем, ПрименятьПоиск);
    КонецЦикла;
    
    ЗначениеВРеквизитФормы(Дерево, "ДеревоПодсистем");
    
КонецПроцедуры

&НаСервере
Функция ДобавитьПодсистемуВДерево(РодительДерева, Подсистема, ПоискВНижнем, ПрименятьПоиск)
    
    СтрокаСоответствует = НЕ ПрименятьПоиск;
    Если ПрименятьПоиск Тогда
        СтрокаДляПоиска = НРег(Подсистема.Имя + "|" + Подсистема.Синоним + "|" + Подсистема.ПолноеИмя());
        СтрокаСоответствует = СтрНайти(СтрокаДляПоиска, ПоискВНижнем) > 0;
    КонецЕсли;
    
    НовыйУзел = РодительДерева.Строки.Добавить();
    НовыйУзел.Имя           = Подсистема.Имя;
    НовыйУзел.ПолноеИмя     = Подсистема.ПолноеИмя();
    НовыйУзел.Представление = ?(ПустаяСтрока(Подсистема.Синоним), Подсистема.Имя, Подсистема.Синоним);
    
    ЕстьВидимыеДети = Ложь;
    Для Каждого ВложеннаяПС Из Подсистема.Подсистемы Цикл
        Если ДобавитьПодсистемуВДерево(НовыйУзел, ВложеннаяПС, ПоискВНижнем, ПрименятьПоиск) Тогда
            ЕстьВидимыеДети = Истина;
        КонецЕсли;
    КонецЦикла;
    
    Если ПрименятьПоиск И НЕ СтрокаСоответствует И НЕ ЕстьВидимыеДети Тогда
        РодительДерева.Строки.Удалить(НовыйУзел);
        Возврат Ложь;
    КонецЕсли;
    
    Возврат Истина;
    
КонецФункции

&НаКлиенте
Процедура РазвернутьИлиСвернутьВсе(Развернуть)
    Для Каждого СтрокаУровня1 Из ДеревоПодсистем.ПолучитьЭлементы() Цикл
        РазвернутьУзелРекурсивно(СтрокаУровня1, Развернуть);
    КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьУзелРекурсивно(Узел, Развернуть)
    Идентификатор = Узел.ПолучитьИдентификатор();
    Если Развернуть Тогда
        Элементы.ДеревоПодсистем.Развернуть(Идентификатор, Ложь);
    Иначе
        Элементы.ДеревоПодсистем.Свернуть(Идентификатор);
    КонецЕсли;
    Для Каждого Ребёнок Из Узел.ПолучитьЭлементы() Цикл
        РазвернутьУзелРекурсивно(Ребёнок, Развернуть);
    КонецЦикла;
КонецПроцедуры

#КонецОбласти