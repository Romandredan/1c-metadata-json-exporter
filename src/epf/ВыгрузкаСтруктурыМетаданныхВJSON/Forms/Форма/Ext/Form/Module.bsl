
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    // Инициализируем значения реквизитов формы из программного API объекта обработки
    // — единый источник истины для значений по умолчанию.
    ЗаполнитьЗначенияПоУмолчанию();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
    // Управляем видимостью/доступностью после того, как форма открылась.
    // Делаем это на клиенте, чтобы не плодить пару "клиент+сервер" с одинаковым кодом.
    УправлениеВидимостьюПолей();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗначенияПоУмолчанию()
    ОбработкаОбъект = РеквизитФормыВЗначение("Объект"); // "Объект" — стандартный реквизит формы обработки
    ПараметрыПоУмолчанию = ОбработкаОбъект.НовыеПараметрыВыгрузки();
    ЗаполнитьЗначенияСвойств(ЭтаФорма, ПараметрыПоУмолчанию);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийРеквизитовФормы

&НаКлиенте
Процедура РежимПриИзменении(Элемент)
    УправлениеВидимостьюПолей();
КонецПроцедуры

&НаКлиенте
Процедура РежимСсылочныхТиповПриИзменении(Элемент)
    УправлениеВидимостьюПолей();
КонецПроцедуры

&НаКлиенте
Процедура ПапкаВыгрузкиОткрытие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	 Если ПустаяСтрока(ПапкаВыгрузки) Тогда
        ПоказатьПредупреждение(, НСтр("ru = 'Не указана папка выгрузки.'"));
        Возврат;
    КонецЕсли;
    
    ОписаниеОповещения = Новый ОписаниеОповещения("ОткрытьПапкуВыгрузкиПослеПроверки", ЭтотОбъект);
    ПроверитьСуществованиеПапки(ПапкаВыгрузки, ОписаниеОповещения);
КонецПроцедуры        

&НаКлиенте
Процедура ПроверитьСуществованиеПапки(Путь, ОписаниеОповещения)
    Файл = Новый Файл(Путь);
    Файл.НачатьПроверкуСуществования(
        Новый ОписаниеОповещения("ПроверитьСуществованиеПапкиЗавершение", ЭтотОбъект,
            Новый Структура("Путь, ВнешнееОповещение", Путь, ОписаниеОповещения)));
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСуществованиеПапкиЗавершение(Существует, ДопПараметры) Экспорт
    
    Если НЕ Существует Тогда
        ТекстВопроса = СтрШаблон(
            НСтр("ru = 'Папка %1 не существует. Создать её?'"),
            ДопПараметры.Путь);
        ОписаниеОтвета = Новый ОписаниеОповещения("ОбработатьОтветНаСоздание", ЭтотОбъект, ДопПараметры);
        ПоказатьВопрос(ОписаниеОтвета, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
        Возврат;
    КонецЕсли;
    
    ВыполнитьОбработкуОповещения(ДопПараметры.ВнешнееОповещение, Истина);
    
КонецПроцедуры 

&НаКлиенте
Процедура ОбработатьОтветНаСоздание(Ответ, ДопПараметры) Экспорт
    
    Если Ответ <> КодВозвратаДиалога.Да Тогда
        Возврат;
    КонецЕсли;
    
    Попытка
        СоздатьКаталог(ДопПараметры.Путь);
    Исключение
        ПоказатьПредупреждение(,
            СтрШаблон(НСтр("ru = 'Не удалось создать папку: %1'"),
            КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
        Возврат;
    КонецПопытки;
    
    ВыполнитьОбработкуОповещения(ДопПараметры.ВнешнееОповещение, Истина);
    
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПапкуВыгрузкиПослеПроверки(Результат, ДопПараметры) Экспорт
    
    Если Результат <> Истина Тогда
        Возврат;
    КонецЕсли;
    
    // ЗапуститьПриложение с путём к папке — открывается в проводнике ОС.
    // Под Windows — Проводник, под Linux — менеджер файлов по умолчанию, под macOS — Finder.
    Попытка
        #Если ВебКлиент Тогда
            ПоказатьПредупреждение(, НСтр("ru = 'Открытие папки недоступно в веб-клиенте.'"));
        #Иначе
            ЗапуститьПриложение(ПапкаВыгрузки);
        #КонецЕсли
    Исключение
        ПоказатьПредупреждение(,
            СтрШаблон(НСтр("ru = 'Не удалось открыть папку: %1'"),
            КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
    КонецПопытки;
    
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиНачалаВыбора

&НаКлиенте
Процедура ОбъектВыгрузкиНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
    
    СтандартнаяОбработка = Ложь;
    
    ПараметрыФормы = Новый Структура;
    ПараметрыФормы.Вставить("РежимВыбораМножественный", Ложь);
    ПараметрыФормы.Вставить("Заголовок", НСтр("ru = 'Выбор объекта метаданных для выгрузки'"));
    
    Оповещение = Новый ОписаниеОповещения("ОбъектВыгрузкиНачалоВыбораЗавершение", ЭтотОбъект);
    ОткрытьФорму(ПолноеИмяФормыОбработки(ЭтаФорма.ИмяФормы, "ФормаВыбораМетаданных"),
        ПараметрыФормы, ЭтаФорма, , , , Оповещение,
        РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
    
КонецПроцедуры 
	
&НаКлиенте
Процедура ОбъектВыгрузкиНачалоВыбораЗавершение(РезультатВыбора, ДопПараметры) Экспорт
    Если РезультатВыбора = Неопределено Тогда
        Возврат;
    КонецЕсли;
    // РезультатВыбора — строка полного имени, например "Документ.РеализацияТоваровУслуг".
    ОбъектВыгрузки = РезультатВыбора;
КонецПроцедуры

&НаКлиенте
Процедура ПодсистемаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
    
    СтандартнаяОбработка = Ложь;
    
    ПараметрыФормы = Новый Структура;
    ПараметрыФормы.Вставить("ТекущаяПодсистема", Подсистема);
    
    Оповещение = Новый ОписаниеОповещения("ПодсистемаНачалоВыбораЗавершение", ЭтотОбъект);
    ОткрытьФорму(ПолноеИмяФормыОбработки(ЭтаФорма.ИмяФормы, "ФормаВыбораПодсистемы"),
        ПараметрыФормы, ЭтаФорма, , , , Оповещение,
        РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
    
КонецПроцедуры

&НаКлиенте
Процедура ПодсистемаНачалоВыбораЗавершение(РезультатВыбора, ДопПараметры) Экспорт
    Если РезультатВыбора = Неопределено Тогда
        Возврат;
    КонецЕсли;
    // РезультатВыбора — строка вида "Подсистема.Продажи.Розница".
    Подсистема = РезультатВыбора;
КонецПроцедуры

&НаКлиенте
Процедура СписокОбъектовНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
    
    СтандартнаяОбработка = Ложь;
    
    МассивУжеВыбранных = Новый Массив;
    Для Каждого ЭлементСЗ Из СписокОбъектов Цикл
        МассивУжеВыбранных.Добавить(ЭлементСЗ.Значение);
    КонецЦикла;
    
    ПараметрыФормы = Новый Структура;
    ПараметрыФормы.Вставить("РежимВыбораМножественный", Истина);
    ПараметрыФормы.Вставить("УжеВыбранные",             МассивУжеВыбранных);
    ПараметрыФормы.Вставить("Заголовок",                НСтр("ru = 'Выбор объектов метаданных для выгрузки'"));
    
    Оповещение = Новый ОписаниеОповещения("СписокОбъектовНачалоВыбораЗавершение", ЭтотОбъект);
    ОткрытьФорму(ПолноеИмяФормыОбработки(ЭтаФорма.ИмяФормы, "ФормаВыбораМетаданных"),
        ПараметрыФормы, ЭтаФорма, , , , Оповещение,
        РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
    
КонецПроцедуры

&НаКлиенте
Процедура СписокОбъектовНачалоВыбораЗавершение(РезультатВыбора, ДопПараметры) Экспорт
    
    Если РезультатВыбора = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    // РезультатВыбора — массив строк полных имён.
    СписокПредставлений = ПолучитьПредставленияОбъектовМетаданных(РезультатВыбора);
    
    СписокОбъектов.Очистить();
    Для Каждого ПолноеИмя Из РезультатВыбора Цикл
        Представление = СписокПредставлений.Получить(ПолноеИмя);
        Если Представление = Неопределено Тогда
            Представление = ПолноеИмя;
        КонецЕсли;
        СписокОбъектов.Добавить(ПолноеИмя, Представление);
    КонецЦикла;
    
КонецПроцедуры

&НаКлиенте
Процедура ПапкаВыгрузкиНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
    СтандартнаяОбработка = Ложь;
    Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
    Диалог.Заголовок = "Выберите папку для выгрузки JSON";
    Если Диалог.Выбрать() Тогда
        ПапкаВыгрузки = Диалог.Каталог;
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область КомандыФормы

&НаКлиенте
Процедура Выгрузить(Команда)
    ТекстОшибки = ПроверитьВводНаКлиенте();
    Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
        ПоказатьПредупреждение(, ТекстОшибки);
        Возврат;
    КонецЕсли;

    Состояние("Выполняется выгрузка структуры метаданных в JSON...");
    Результат = ВыгрузитьНаСервере();
    Состояние();

    Если Результат.Успех Тогда
        ПоказатьОповещениеПользователя(
            "Выгрузка завершена",
            ,
            "Создано файлов: " + Результат.СозданныеФайлы.Количество() + Символы.ПС
                + "Папка: " + ПапкаВыгрузки);
    Иначе
        ПоказатьПредупреждение(, Результат.СообщениеОбОшибке);
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СерверныеВызовы

&НаСервере
Функция ВыгрузитьНаСервере()
    // Единственная точка обращения к бизнес-логике — через программный API модуля объекта.
    ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
    ПараметрыВыгрузки = ОбработкаОбъект.НовыеПараметрыВыгрузки();
    // Копируем одноимённые поля из реквизитов формы в структуру параметров.
    // Реквизит формы специально назван ОбъектВыгрузки, чтобы не конфликтовать
    // со стандартным реквизитом "Объект" формы обработки.
    ЗаполнитьЗначенияСвойств(ПараметрыВыгрузки, ЭтаФорма);
    Возврат ОбработкаОбъект.Выгрузить(ПараметрыВыгрузки);
КонецФункции   



#КонецОбласти

#Область УправлениеИнтерфейсом

&НаКлиенте
Процедура УправлениеВидимостьюПолей()
    // Единая клиентская процедура. Серверной версии нет — в управляемой форме
    // свойства элементов доступны на клиенте напрямую, серверный вызов не требуется.
    Элементы.ОбъектВыгрузки.Видимость                     = (Режим = "Один");
    Элементы.СписокОбъектов.Видимость                     = (Режим = "Список");
    Элементы.Подсистема.Видимость                         = (Режим = "Подсистема");
    Элементы.ВыгружатьОбъектыВложенныхПодсистем.Видимость = (Режим = "Подсистема");
    Элементы.ГлубинаВложенности.Доступность               = (РежимСсылочныхТипов = "Раскрывать");
КонецПроцедуры

#КонецОбласти

#Область ВалидацияВвода

&НаКлиенте
Функция ПроверитьВводНаКлиенте()
    Если ПустаяСтрока(ПапкаВыгрузки) Тогда
        Возврат "Укажите папку выгрузки.";
    КонецЕсли;
    Если Режим = "Один" И НЕ ЗначениеЗаполнено(ОбъектВыгрузки) Тогда
        Возврат "Выберите объект метаданных.";
    КонецЕсли;
    Если Режим = "Список" И (СписокОбъектов = Неопределено ИЛИ СписокОбъектов.Количество() = 0) Тогда
        Возврат "Заполните список объектов.";
    КонецЕсли;
    Если Режим = "Подсистема" И НЕ ЗначениеЗаполнено(Подсистема) Тогда
        Возврат "Выберите подсистему.";
    КонецЕсли;
    Если РежимСсылочныхТипов = "Раскрывать" И (ГлубинаВложенности < 1 ИЛИ ГлубинаВложенности > 3) Тогда
        Возврат "Глубина вложенности должна быть от 1 до 3.";
    КонецЕсли;
    Возврат "";
КонецФункции

#КонецОбласти

#Область ВспомогательныеФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолноеИмяФормыОбработки(Знач ИмяТекущейФормы, Знач ИмяЦелевойФормы)
    // Преобразует "ВнешняяОбработка.ХХХ.Форма.Форма" в "ВнешняяОбработка.ХХХ.Форма.<ИмяЦелевой>".
    Позиция = СтрНайти(ИмяТекущейФормы, ".Форма.");
    Если Позиция = 0 Тогда
        Возврат ИмяЦелевойФормы;
    КонецЕсли;
    Возврат Лев(ИмяТекущейФормы, Позиция + СтрДлина(".Форма.") - 1) + ИмяЦелевойФормы;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьПредставленияОбъектовМетаданных(МассивПолныхИмён)
    
    Результат = Новый Соответствие;
    
    Для Каждого ПолноеИмя Из МассивПолныхИмён Цикл
        ОбъектМД = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
        Если ОбъектМД = Неопределено Тогда
            Результат.Вставить(ПолноеИмя, ПолноеИмя);
            Продолжить;
        КонецЕсли;
        Синоним = ОбъектМД.Синоним;
        Представление = ?(ПустаяСтрока(Синоним),
            ПолноеИмя,
            Синоним + " (" + ПолноеИмя + ")");
        Результат.Вставить(ПолноеИмя, Представление);
    КонецЦикла;
    
    Возврат Результат;
    
КонецФункции 

#КонецОбласти