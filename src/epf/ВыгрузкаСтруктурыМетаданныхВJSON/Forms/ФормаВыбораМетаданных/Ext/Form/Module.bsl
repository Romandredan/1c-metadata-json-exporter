#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    
    РежимМножественный = Ложь;
    Если Параметры.Свойство("РежимВыбораМножественный") Тогда
        РежимМножественный = Параметры.РежимВыбораМножественный;
    КонецЕсли;
    
    Если Параметры.Свойство("Заголовок") И ЗначениеЗаполнено(Параметры.Заголовок) Тогда
        Заголовок = Параметры.Заголовок;
    Иначе
        Заголовок = ?(РежимМножественный,
            НСтр("ru = 'Выбор объектов метаданных'"),
            НСтр("ru = 'Выбор объекта метаданных'"));
    КонецЕсли;
	
	ПоказыватьДокументы 			= Истина;
	ПоказыватьСправочники 			= Истина;
	ПоказыватьРегистрыСведений 		= Истина;
	ПоказыватьРегистрыНакопления 	= Истина;
	
    Элементы.ДеревоМетаданныхВыбран.Видимость   = РежимМножественный;
    Элементы.ФормаОтметитьВсеВГруппе.Видимость  = РежимМножественный;
    Элементы.ФормаСнятьВсеОтметки.Видимость     = РежимМножественный;
    
    ПостроитьДерево();
    
    Если РежимМножественный И Параметры.Свойство("УжеВыбранные") Тогда
        ПредотметитьУжеВыбранные(Параметры.УжеВыбранные);
    КонецЕсли;
    
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийРеквизитов

&НаКлиенте
Процедура СтрокаПоискаПриИзменении(Элемент)
    ПерестроитьДеревоСохранивОтметки();
КонецПроцедуры

&НаКлиенте
Процедура ФильтрКоллекцийПриИзменении(Элемент)
    ПерестроитьДеревоСохранивОтметки();
КонецПроцедуры

&НаКлиенте
Процедура ВыбранПриИзменении(Элемент)
    ТекущиеДанные = Элементы.ДеревоМетаданных.ТекущиеДанные;
    Если ТекущиеДанные = Неопределено Тогда
        Возврат;
    КонецЕсли;
    Если ТекущиеДанные.ЭтоГруппа Тогда
        УстановитьОтметкуДетям(Элементы.ДеревоМетаданных.ТекущаяСтрока, ТекущиеДанные.Выбран);
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиТаблицыДерева

&НаКлиенте
Процедура ДеревоМетаданныхВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
    СтандартнаяОбработка = Ложь;
    Если РежимМножественный Тогда
        ПереключитьОтметку(ВыбраннаяСтрока);
    Иначе
        ВыбратьВыполнить(Неопределено);
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКоманд

&НаКлиенте
Процедура ВыбратьВыполнить(Команда)
    
    Если РежимМножественный Тогда
        МассивПолныхИмён = СобратьОтмеченные();
        Если МассивПолныхИмён.Количество() = 0 Тогда
            ПоказатьПредупреждение(, НСтр("ru = 'Не отмечено ни одного объекта.'"));
            Возврат;
        КонецЕсли;
        ОповеститьОВыборе(МассивПолныхИмён);
    Иначе
        ТекущиеДанные = Элементы.ДеревоМетаданных.ТекущиеДанные;
        Если ТекущиеДанные = Неопределено Тогда
            ПоказатьПредупреждение(, НСтр("ru = 'Выберите объект метаданных.'"));
            Возврат;
        КонецЕсли;
        Если ТекущиеДанные.ЭтоГруппа Тогда
            ПоказатьПредупреждение(, НСтр("ru = 'Выберите объект метаданных, а не группу коллекций.'"));
            Возврат;
        КонецЕсли;
        Если ПустаяСтрока(ТекущиеДанные.ПолноеИмя) Тогда
            ПоказатьПредупреждение(, НСтр("ru = 'Не удалось определить полное имя объекта.'"));
            Возврат;
        КонецЕсли;
        ОповеститьОВыборе(ТекущиеДанные.ПолноеИмя);
    КонецЕсли;
    
КонецПроцедуры

&НаКлиенте
Процедура ОтменаВыполнить(Команда)
    Закрыть(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ОтметитьВсеВГруппе(Команда)
    
    ТекущаяСтрока = Элементы.ДеревоМетаданных.ТекущаяСтрока;
    Если ТекущаяСтрока = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    ТекущиеДанные = Элементы.ДеревоМетаданных.ДанныеСтроки(ТекущаяСтрока);
    Если ТекущиеДанные = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    Если НЕ ТекущиеДанные.ЭтоГруппа Тогда
        СтрокаРодитель = НайтиРодителяСтроки(ТекущаяСтрока);
        Если СтрокаРодитель = Неопределено Тогда
            Возврат;
        КонецЕсли;
        ИдентификаторГруппы = СтрокаРодитель.ПолучитьИдентификатор();
    Иначе
        ИдентификаторГруппы = ТекущаяСтрока;
        ТекущиеДанные.Выбран = Истина;
    КонецЕсли;
    
    УстановитьОтметкуДетям(ИдентификаторГруппы, Истина);
    
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсеОтметки(Команда)
    СнятьВсеОтметкиНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьВсё(Команда)
    РазвернутьИлиСвернутьВсе(Истина);
КонецПроцедуры

&НаКлиенте
Процедура СвернутьВсё(Команда)
    РазвернутьИлиСвернутьВсе(Ложь);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПерестроитьДеревоСохранивОтметки()
    Отмеченные = СобратьОтмеченные();
    ПерестроитьДеревоНаСервере(Отмеченные);
КонецПроцедуры

&НаСервере
Процедура ПерестроитьДеревоНаСервере(Отмеченные)
    ПостроитьДерево();
    ВосстановитьОтметки(Отмеченные);
КонецПроцедуры

&НаСервере
Процедура ПостроитьДерево()
    
    Дерево = РеквизитФормыВЗначение("ДеревоМетаданных");
    Дерево.Строки.Очистить();
    
    ПоискВНижнем = НРег(СокрЛП(СтрокаПоиска));
    ПрименятьПоиск = НЕ ПустаяСтрока(ПоискВНижнем);
    
    Коллекции = ПолучитьКоллекции();
    
    Для Каждого КоллекцияЭлемент Из Коллекции Цикл
        
        Если НЕ КоллекцияЭлемент.Показывать Тогда
            Продолжить;
        КонецЕсли;
        
        ВетвьГруппы = Дерево.Строки.Добавить();
        ВетвьГруппы.Имя           = КоллекцияЭлемент.Имя;
        ВетвьГруппы.ПолноеИмя     = КоллекцияЭлемент.Имя;
        ВетвьГруппы.Представление = КоллекцияЭлемент.Представление;
        ВетвьГруппы.ЭтоГруппа     = Истина;
        
        ЕстьВидимыеДети = Ложь;
        Для Каждого ОбъектМД Из КоллекцияЭлемент.Коллекция Цикл
            
            Синоним  = ОбъектМД.Синоним;
            Помечен  = СтрНачинаетсяС(Синоним, "(Удалить)")
                    ИЛИ СтрНачинаетсяС(ОбъектМД.Имя, "Удалить");
            
            Если СкрыватьПомеченныеНаУдаление И Помечен Тогда
                Продолжить;
            КонецЕсли;
            
            Представление = ?(ПустаяСтрока(Синоним), ОбъектМД.Имя, Синоним);
            ПолноеИмя     = ОбъектМД.ПолноеИмя();
            
            Если ПрименятьПоиск Тогда
                Строка = НРег(ОбъектМД.Имя + "|" + Синоним + "|" + ПолноеИмя);
                Если СтрНайти(Строка, ПоискВНижнем) = 0 Тогда
                    Продолжить;
                КонецЕсли;
            КонецЕсли;
            
            ВетвьОбъекта = ВетвьГруппы.Строки.Добавить();
            ВетвьОбъекта.Имя           = ОбъектМД.Имя;
            ВетвьОбъекта.ПолноеИмя     = ПолноеИмя;
            ВетвьОбъекта.Представление = Представление;
            ВетвьОбъекта.ЭтоГруппа     = Ложь;
            ВетвьОбъекта.Помечен       = Помечен;
            
            ЕстьВидимыеДети = Истина;
            
        КонецЦикла;
        
        Если НЕ ЕстьВидимыеДети Тогда
            Дерево.Строки.Удалить(ВетвьГруппы);
        КонецЕсли;
        
    КонецЦикла;
    
    ЗначениеВРеквизитФормы(Дерево, "ДеревоМетаданных");
    
КонецПроцедуры

&НаСервере
Функция ПолучитьКоллекции()
    
    Результат = Новый Массив;
    ДобавитьКоллекцию(Результат, "Справочник",             НСтр("ru = 'Справочники'"),               Метаданные.Справочники,             ПоказыватьСправочники);
    ДобавитьКоллекцию(Результат, "Документ",               НСтр("ru = 'Документы'"),                 Метаданные.Документы,               ПоказыватьДокументы);
    ДобавитьКоллекцию(Результат, "Перечисление",           НСтр("ru = 'Перечисления'"),              Метаданные.Перечисления,            ПоказыватьПеречисления);
    ДобавитьКоллекцию(Результат, "ПланВидовХарактеристик", НСтр("ru = 'Планы видов характеристик'"), Метаданные.ПланыВидовХарактеристик, ПоказыватьПланыВидовХарактеристик);
    ДобавитьКоллекцию(Результат, "ПланСчетов",             НСтр("ru = 'Планы счетов'"),              Метаданные.ПланыСчетов,             ПоказыватьПланыСчетов);
    ДобавитьКоллекцию(Результат, "ПланВидовРасчета",       НСтр("ru = 'Планы видов расчёта'"),       Метаданные.ПланыВидовРасчета,       ПоказыватьПланыВидовРасчета);
    ДобавитьКоллекцию(Результат, "РегистрСведений",        НСтр("ru = 'Регистры сведений'"),         Метаданные.РегистрыСведений,        ПоказыватьРегистрыСведений);
    ДобавитьКоллекцию(Результат, "РегистрНакопления",      НСтр("ru = 'Регистры накопления'"),       Метаданные.РегистрыНакопления,      ПоказыватьРегистрыНакопления);
    ДобавитьКоллекцию(Результат, "РегистрБухгалтерии",     НСтр("ru = 'Регистры бухгалтерии'"),      Метаданные.РегистрыБухгалтерии,     ПоказыватьРегистрыБухгалтерии);
    ДобавитьКоллекцию(Результат, "РегистрРасчета",         НСтр("ru = 'Регистры расчёта'"),          Метаданные.РегистрыРасчета,         ПоказыватьРегистрыРасчета);
    ДобавитьКоллекцию(Результат, "ПланОбмена",             НСтр("ru = 'Планы обмена'"),              Метаданные.ПланыОбмена,             ПоказыватьПланыОбмена);
    ДобавитьКоллекцию(Результат, "БизнесПроцесс",          НСтр("ru = 'Бизнес-процессы'"),           Метаданные.БизнесПроцессы,          ПоказыватьБизнесПроцессы);
    ДобавитьКоллекцию(Результат, "Задача",                 НСтр("ru = 'Задачи'"),                    Метаданные.Задачи,                  ПоказыватьЗадачи);
    Возврат Результат;
    
КонецФункции

&НаСервере
Процедура ДобавитьКоллекцию(Массив, Имя, Представление, Коллекция, Показывать)
    Элемент = Новый Структура;
    Элемент.Вставить("Имя",           Имя);
    Элемент.Вставить("Представление", Представление);
    Элемент.Вставить("Коллекция",     Коллекция);
    Элемент.Вставить("Показывать",    Показывать);
    Массив.Добавить(Элемент);
КонецПроцедуры

&НаКлиенте
Функция СобратьОтмеченные()
    Результат = Новый Массив;
    Для Каждого СтрокаГруппы Из ДеревоМетаданных.ПолучитьЭлементы() Цикл
        Для Каждого СтрокаОбъекта Из СтрокаГруппы.ПолучитьЭлементы() Цикл
            Если СтрокаОбъекта.Выбран Тогда
                Результат.Добавить(СтрокаОбъекта.ПолноеИмя);
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    Возврат Результат;
КонецФункции

&НаСервере
Процедура ВосстановитьОтметки(МассивПолныхИмён)
    
    Если МассивПолныхИмён.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;
    
    Множество = Новый Соответствие;
    Для Каждого ПИ Из МассивПолныхИмён Цикл
        Множество.Вставить(ПИ, Истина);
    КонецЦикла;
    
    Для Каждого СтрокаГруппы Из ДеревоМетаданных.ПолучитьЭлементы() Цикл
        Для Каждого СтрокаОбъекта Из СтрокаГруппы.ПолучитьЭлементы() Цикл
            Если Множество.Получить(СтрокаОбъекта.ПолноеИмя) = Истина Тогда
                СтрокаОбъекта.Выбран = Истина;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    
КонецПроцедуры

&НаКлиенте
Процедура ПереключитьОтметку(ВыбраннаяСтрока)
    
    Данные = Элементы.ДеревоМетаданных.ДанныеСтроки(ВыбраннаяСтрока);
    Если Данные = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    Если Данные.ЭтоГруппа Тогда
        Данные.Выбран = НЕ Данные.Выбран;
        УстановитьОтметкуДетям(ВыбраннаяСтрока, Данные.Выбран);
    Иначе
        Данные.Выбран = НЕ Данные.Выбран;
    КонецЕсли;
    
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтметкуДетям(ИдентификаторГруппы, Значение)
    СтрокаГруппы = НайтиСтрокуПоИдентификатору(ИдентификаторГруппы);
    Если СтрокаГруппы = Неопределено Тогда
        Возврат;
    КонецЕсли;
    Для Каждого Ребёнок Из СтрокаГруппы.ПолучитьЭлементы() Цикл
        Ребёнок.Выбран = Значение;
    КонецЦикла;
КонецПроцедуры

&НаКлиенте
Функция НайтиСтрокуПоИдентификатору(Идентификатор)
    Для Каждого СтрокаГруппы Из ДеревоМетаданных.ПолучитьЭлементы() Цикл
        Если СтрокаГруппы.ПолучитьИдентификатор() = Идентификатор Тогда
            Возврат СтрокаГруппы;
        КонецЕсли;
    КонецЦикла;
    Возврат Неопределено;
КонецФункции

&НаКлиенте
Функция НайтиРодителяСтроки(ИдентификаторСтроки)
    Для Каждого СтрокаГруппы Из ДеревоМетаданных.ПолучитьЭлементы() Цикл
        Для Каждого Ребёнок Из СтрокаГруппы.ПолучитьЭлементы() Цикл
            Если Ребёнок.ПолучитьИдентификатор() = ИдентификаторСтроки Тогда
                Возврат СтрокаГруппы;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    Возврат Неопределено;
КонецФункции

&НаСервере
Процедура СнятьВсеОтметкиНаСервере()
    Для Каждого СтрокаГруппы Из ДеревоМетаданных.ПолучитьЭлементы() Цикл
        СтрокаГруппы.Выбран = Ложь;
        Для Каждого СтрокаОбъекта Из СтрокаГруппы.ПолучитьЭлементы() Цикл
            СтрокаОбъекта.Выбран = Ложь;
        КонецЦикла;
    КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПредотметитьУжеВыбранные(МассивПолныхИмён)
    
    Если МассивПолныхИмён = Неопределено ИЛИ МассивПолныхИмён.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;
    
    Множество = Новый Соответствие;
    Для Каждого ПолноеИмя Из МассивПолныхИмён Цикл
        Если НЕ ПустаяСтрока(ПолноеИмя) Тогда
            Множество.Вставить(ПолноеИмя, Истина);
        КонецЕсли;
    КонецЦикла;
    
    Для Каждого СтрокаГруппы Из ДеревоМетаданных.ПолучитьЭлементы() Цикл
        Для Каждого СтрокаОбъекта Из СтрокаГруппы.ПолучитьЭлементы() Цикл
            Если Множество.Получить(СтрокаОбъекта.ПолноеИмя) = Истина Тогда
                СтрокаОбъекта.Выбран = Истина;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьИлиСвернутьВсе(Развернуть)
    Для Каждого СтрокаУровня1 Из ДеревоМетаданных.ПолучитьЭлементы() Цикл
        РазвернутьУзелРекурсивно(СтрокаУровня1, Развернуть);
    КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьУзелРекурсивно(Узел, Развернуть)
    Идентификатор = Узел.ПолучитьИдентификатор();
    Если Развернуть Тогда
        Элементы.ДеревоМетаданных.Развернуть(Идентификатор, Ложь);
    Иначе
        Элементы.ДеревоМетаданных.Свернуть(Идентификатор);
    КонецЕсли;
    Для Каждого Ребёнок Из Узел.ПолучитьЭлементы() Цикл
        РазвернутьУзелРекурсивно(Ребёнок, Развернуть);
    КонецЦикла;
КонецПроцедуры

#КонецОбласти