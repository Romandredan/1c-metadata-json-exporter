root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Исходники 1С — CRLF (как требует платформа)
[*.{bsl,os,xml}]
end_of_line = crlf

# Windows-скрипты — CRLF
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Разметка и конфиги
[*.{md,json,yml,yaml}]
indent_size = 2

# Makefile (если появится)
[Makefile]
indent_style = tab
