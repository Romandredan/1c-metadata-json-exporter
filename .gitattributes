# Общие правила
* text=auto

# Исходники 1С (BSL) и OneScript — CRLF, как требует платформа
*.bsl text eol=crlf
*.os  text eol=crlf

# XML-дескрипторы конфигуратора — CRLF
*.xml text eol=crlf

# Разметка и конфиги — как есть (LF по умолчанию, Git нормализует)
*.md   text
*.json text
*.yml  text
*.yaml text

# Windows-скрипты, если появятся — CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell-скрипты — LF
*.sh text eol=lf

# Бинарные артефакты 1С
*.epf binary
*.erf binary
*.cf  binary
*.cfe binary
Form.bin binary
ParentConfigurations.bin binary

# Графика/архивы
*.png  binary
*.ico  binary
*.jpg  binary
*.jpeg binary
*.zip  binary
*.7z   binary
*.gz   binary
*.tar  binary
*.tgz  binary
