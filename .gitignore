# Секреты и локальное окружение
.env
.env.*
!.env.example

# Артефакты сборки/запуска
build/
out/
dist/

# Служебные файлы 1С/EDT
ConfigDumpInfo.xml

# Сборки 1С: бинарники не коммитим, кроме явно публикуемых релизов в releases/
*.epf
*.cf
*.cfu
*.cfe
!releases/*.epf

# OS
Thumbs.db
.DS_Store
desktop.ini

# Логи
*.log
logs/

# Кэш и временные
*.bak
*.tmp
~$*

# IDE
.idea/
.vscode/
*.iml

# Kiro: в репо только описание проекта (project.md).
# Личная обвязка агента (MCP-настройки, steering под конкретные инструменты) — локальная, не коммитим.
.kiro/*
!.kiro/steering/
.kiro/steering/*
!.kiro/steering/project.md

# Serena: коммитим только описание проекта, кэш и локальный конфиг — игнорируем
.serena/*
!.serena/.gitignore
!.serena/project.yml
